NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: full base URL of the site that serves POST /api/public-lead (e.g. production CRM URL).
# Leave unset to use same-origin /api/public-lead (Vercel serverless or Vite dev proxy to backend).
# VITE_PUBLIC_LEAD_API_URL=https://your-crm.example.com